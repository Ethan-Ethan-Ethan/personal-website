---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/articles/', label: '文章' },
  { href: '/protected/resume', label: '履歷' },
  { href: '/protected/vlog', label: 'Vlog' },
];
---

<header class="fixed top-0 left-0 right-0 z-40 bg-bg/90 backdrop-blur-sm border-b border-line">
  <div class="max-w-[var(--container-wide)] mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 no-underline text-text hover:text-green transition-colors" aria-label="Ethan Yang dashboard">
      <span class="w-8 h-8 rounded-md bg-panel-2 border border-line flex items-center justify-center text-xs font-bold tracking-wider text-muted">EY</span>
      <span>
        <strong class="text-sm font-semibold">Ethan Yang</strong>
        <span class="block text-xs text-soft leading-none">Personal website</span>
      </span>
    </a>
    <nav class="flex items-center gap-4" aria-label="Primary navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm no-underline transition-colors',
            currentPath.startsWith(href) ? 'text-green font-semibold' : 'text-muted hover:text-text'
          ]}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
