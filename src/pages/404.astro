---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
---

<BaseLayout title="404 | 找不到頁面">
  <Topbar />
  <main class="pt-14 flex items-center justify-center min-h-[60vh]">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-muted mb-4">404</h1>
      <p class="text-muted mb-6">找不到這個頁面</p>
      <a href="/" class="text-sm text-blue hover:text-green transition-colors">← 返回首頁</a>
    </div>
  </main>
</BaseLayout>
