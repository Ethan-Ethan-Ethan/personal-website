---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentPosts = posts.slice(0, 6);
---

<BaseLayout title="Ethan Yang | Personal Website" description="Ethan Yang 的個人網站 — FAE / AI 工程 / 技術寫作，從現場到產品的橋樑工程師。">
  <Topbar />

  <main class="pt-14">
    <!-- Hero Section -->
    <section class="max-w-[var(--container-wide)] mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 items-start">
        <!-- Left: Intro -->
        <div>
          <p class="text-sm text-amber tracking-widest uppercase mb-2">FAE / AI 工程 / 技術寫作</p>
          <h1 class="text-4xl font-extrabold tracking-tight leading-tight mb-4">從現場到產品的橋樑工程師</h1>
          <p class="text-muted text-md leading-relaxed mb-6 max-w-[600px]">
            5 年電源設計與 FAE 經驗，專注於技術落地與知識系統化。這裡整理我的工作方法、投資心得，以及可公開閱讀的文章。
          </p>

          <!-- Trust Strip -->
          <div class="flex gap-6 mb-8" aria-label="Career highlights">
            <div class="text-center">
              <strong class="block text-2xl font-bold text-green">5+</strong>
              <span class="text-xs text-soft">年電源設計經驗</span>
            </div>
            <div class="text-center">
              <strong class="block text-2xl font-bold text-blue">APAC</strong>
              <span class="text-xs text-soft">跨國 FAE 支援</span>
            </div>
            <div class="text-center">
              <strong class="block text-2xl font-bold text-amber">100+</strong>
              <span class="text-xs text-soft">篇原子筆記</span>
            </div>
          </div>

          <!-- Summary Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <a href="#posts" class="block p-4 rounded-lg bg-panel border border-line hover:border-soft transition-all no-underline text-text">
              <p class="text-xs text-green mb-1">Articles</p>
              <h3 class="text-md font-semibold mb-1">公開文章</h3>
              <p class="text-sm text-muted mb-2">FAE 價值觀、AI 工作流程、公開筆記</p>
              <div class="flex justify-between text-xs text-soft">
                <span>文章</span>
                <strong>{posts.length} 篇</strong>
              </div>
            </a>
            <a href="/protected/resume" class="block p-4 rounded-lg bg-panel border border-line hover:border-soft transition-all no-underline text-text">
              <p class="text-xs text-blue mb-1">Career</p>
              <h3 class="text-md font-semibold mb-1">工作經驗</h3>
              <p class="text-sm text-muted mb-2">EMC 電源設計 × FAE，從產品驗證到跨國技術支援</p>
              <div class="flex justify-between text-xs text-soft">
                <span>年資</span>
                <strong>5+ 年</strong>
              </div>
            </a>
            <a href="#investing" class="block p-4 rounded-lg bg-panel border border-line hover:border-soft transition-all no-underline text-text">
              <p class="text-xs text-amber mb-1">Investing</p>
              <h3 class="text-md font-semibold mb-1">投資心得</h3>
              <p class="text-sm text-muted mb-2">科技業視角的產業分析與投資框架</p>
              <div class="flex justify-between text-xs text-soft">
                <span>狀態</span>
                <strong>整理中</strong>
              </div>
            </a>
            <a href="/protected/vlog" class="block p-4 rounded-lg bg-panel border border-line hover:border-soft transition-all no-underline text-text">
              <p class="text-xs text-red mb-1">Vlog</p>
              <h3 class="text-md font-semibold mb-1">Vlog 製作</h3>
              <p class="text-sm text-muted mb-2">AI 字幕、聲音克隆、剪輯流程</p>
              <div class="flex justify-between text-xs text-soft">
                <span>主題</span>
                <strong>AI 製作</strong>
              </div>
            </a>
          </div>
        </div>

        <!-- Right: Trading Panel -->
        <aside class="bg-panel border border-line rounded-lg p-4" aria-label="TradingView market dashboard">
          <div class="flex items-center justify-between mb-3">
            <div>
              <h2 class="text-md font-semibold">市場行情</h2>
              <p class="text-xs text-soft">投資交易觀察與內容題材入口</p>
            </div>
            <span class="px-2 py-0.5 rounded-full bg-panel-2 border border-line text-xs text-soft">TradingView</span>
          </div>
          <!-- TradingView Widget -->
          <div class="rounded-md overflow-hidden" style="height:320px;">
            <div id="tradingview-widget" class="h-full"></div>
          </div>
          <!-- Watchlist -->
          <ul class="mt-3 space-y-1">
            <li class="flex items-center justify-between px-2 py-1.5 rounded bg-panel-2 cursor-pointer hover:bg-line/30 transition-colors" data-symbol="BINANCE:BTCUSDT">
              <strong class="text-sm">BTC</strong>
              <span class="text-xs text-muted">比特幣 / USDT</span>
              <span class="text-xs text-green">Primary</span>
            </li>
            <li class="flex items-center justify-between px-2 py-1.5 rounded bg-panel-2 cursor-pointer hover:bg-line/30 transition-colors" data-symbol="BINANCE:ETHUSDT">
              <strong class="text-sm">ETH</strong>
              <span class="text-xs text-muted">以太坊 / USDT</span>
              <span class="text-xs text-blue">Watch</span>
            </li>
            <li class="flex items-center justify-between px-2 py-1.5 rounded bg-panel-2 cursor-pointer hover:bg-line/30 transition-colors" data-symbol="TAIFEX:TMF1!">
              <strong class="text-sm">TMF1!</strong>
              <span class="text-xs text-muted">微型台指期貨</span>
              <span class="text-xs text-blue">Watch</span>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Recent Posts -->
    <section id="posts" class="max-w-[var(--container-default)] mx-auto px-4 pb-10">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold">最新文章</h2>
        <a href="/articles/" class="text-sm text-blue hover:text-green transition-colors no-underline">查看全部 →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentPosts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </section>

    <!-- Investing placeholder -->
    <section id="investing" class="max-w-[var(--container-default)] mx-auto px-4 pb-10">
      <div class="p-6 rounded-lg bg-panel border border-line text-center">
        <h2 class="text-lg font-semibold mb-2">投資心得</h2>
        <p class="text-sm text-muted">科技業視角的產業分析與投資框架，持續累積中。等有穩定成效或可公開方法後，再整理成心得文章。</p>
      </div>
    </section>
  </main>

  <Footer />

  <!-- TradingView Widget Script -->
  <script>
    const widget = document.getElementById('tradingview-widget');
    if (widget && typeof (window as any).TradingView !== 'undefined') {
      new (window as any).TradingView.widget({
        container_id: 'tradingview-widget',
        autosize: true,
        symbol: 'BINANCE:BTCUSDT',
        interval: 'D',
        timezone: 'Asia/Taipei',
        theme: 'dark',
        style: '1',
        locale: 'zh_TW',
        toolbar_bg: '#1b1b18',
        enable_publishing: false,
        hide_top_toolbar: false,
        hide_legend: false,
        save_image: false,
        width: '100%',
        height: '320',
      });
    }

    // Watchlist click handler
    document.querySelectorAll('[data-symbol]').forEach(item => {
      item.addEventListener('click', () => {
        const symbol = item.getAttribute('data-symbol');
        if (symbol && typeof (window as any).TradingView !== 'undefined') {
          const container = document.getElementById('tradingview-widget');
          if (container) {
            container.innerHTML = '';
            new (window as any).TradingView.widget({
              container_id: 'tradingview-widget',
              autosize: true,
              symbol,
              interval: 'D',
              timezone: 'Asia/Taipei',
              theme: 'dark',
              style: '1',
              locale: 'zh_TW',
              toolbar_bg: '#1b1b18',
              enable_publishing: false,
              hide_top_toolbar: false,
              hide_legend: false,
              save_image: false,
              width: '100%',
              height: '320',
            });
          }
        }
      });
    });
  </script>
  <script is:inline src="https://s3.tradingview.com/tv.js" async></script>
</BaseLayout>
