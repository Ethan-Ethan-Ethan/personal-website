---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
---

<BaseLayout title="履歷 | Ethan Yang">
  <Topbar />
  <main class="pt-14 max-w-[var(--container-default)] mx-auto px-4 py-20 text-center">
    <h1 class="text-2xl font-bold mb-4">履歷</h1>
    <p class="text-muted">此頁面由 Cloudflare Access 保護。</p>
